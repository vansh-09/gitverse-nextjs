
# =========================================================
# SERVER CONFIG
# =========================================================
PORT=5000

# =========================================================
# DATABASE
# =========================================================
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST/neondb?sslmode=require&schema=public

# =========================================================
# AUTHENTICATION
# =========================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
NEXTAUTH_SECRET=your-nextauth-secret-key-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# =========================================================
# GOOGLE OAUTH
# =========================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =========================================================
# AI SERVICES
# =========================================================
GEMINI_API_KEY=your_gemini_api_key_here

# =========================================================
# GITHUB APP (AI PR REVIEW SYSTEM)
# =========================================================
# GitHub App (required for automatic PR reviews)
# Create a GitHub App and set:
# - Webhook URL: https://<your-web-url>/api/webhooks/github
# - Webhook secret: (match GITHUB_WEBHOOK_SECRET)
# - Permissions: pull requests (read), contents (read), issues (write) as needed
#
# Note: For GITHUB_APP_PRIVATE_KEY, you can store a multiline key with literal "\n".
# GitHub App ID (found in your GitHub App settings page)
GITHUB_APP_ID=123456
# GitHub App Private Key (download .pem from GitHub App settings, replace newlines with \n)
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_SLUG=your-github-app-slug
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_APP_STATE_SECRET=

# =========================================================
# API
# =========================================================
# GitHub Actions worker trigger (required for immediate production analysis runs)
# Create a token with Actions: write on the repository that contains the worker workflow.
GITHUB_WORKFLOW_REPOSITORY=your-github-owner/your-github-repo
GITHUB_WORKFLOW_TOKEN=your-github-actions-dispatch-token
GITHUB_WORKFLOW_FILE=run-analysis-cron.yml
GITHUB_WORKFLOW_REF=main

# Internal analysis runner secret (REQUIRED in production)
# Protects /api/internal/run-analysis from unauthenticated access.
# Generate a strong random value with: openssl rand -hex 32
# The endpoint will reject ALL requests in production if this is not set.
#
# For Vercel Cron jobs: set CRON_SECRET to the same value. Vercel automatically
# injects "Authorization: Bearer <CRON_SECRET>" on each cron invocation, so
# no additional configuration is needed on the cron side.
ANALYSIS_RUNNER_SECRET=

# Optional: For client-side API calls
NEXT_PUBLIC_API_URL=http://localhost:3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
# Analysis Runner (required for secure analysis job triggering)
ANALYSIS_RUNNER_SECRET=your_analysis_runner_secret_here

# =========================================================
# RATE LIMITING
# =========================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5
# GitLab Integration
GITLAB_API_URL=https://gitlab.com/api/v4
