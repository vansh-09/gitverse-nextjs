{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-worker",
    "module": "CommonJS",
    "target": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "Node",
    "noEmit": false,
    "sourceMap": false,
    "declaration": false,
    "incremental": false
  },
  "include": [
    "scripts/analysisWorker.ts",
    "scripts/workerServer.ts",
    "lib/**/*.ts"
  ]
}
